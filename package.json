{
  "name": "next-secret-guard",
  "version": "0.1.1",
  "description": "CLI-first secret scanning and client-boundary guardrails for Next.js apps.",
  "keywords": [
    "nextjs",
    "next.js",
    "next",
    "security",
    "secret-scanner",
    "secret-exposure",
    "secrets",
    "cli",
    "environment-variables",
    "env",
    "static-analysis",
    "client-component",
    "server-component",
    "prisma",
    "supabase",
    "stripe",
    "openai",
    "clerk",
    "authjs"
  ],
  "author": "Pujan Poudyal <pujan789556@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pujan789556/next-secret-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Pujan789556/next-secret-guard/issues"
  },
  "homepage": "https://github.com/Pujan789556/next-secret-guard#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "next-secret-guard": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts scan",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
